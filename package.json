{
  "name": "mongol-local",
  "version": "0.1.0",
  "private": true,
  "description": "Mongol Local — Yelp-style local business discovery & review platform for Mongolia",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "import:osm": "tsx scripts/import-osm.ts",
    "import:csv": "tsx scripts/import-business-csv.ts",
    "dedupe": "tsx scripts/dedupe-businesses.ts",
    "reindex": "tsx --import ./scripts/_register-server-only.mjs scripts/reindex-search.ts",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "@clickhouse/client": "^1.10.0",
    "@hookform/resolvers": "^3.10.0",
    "@opensearch-project/opensearch": "^3.0.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.64.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.469.0",
    "maplibre-gl": "^4.7.1",
    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.25",
    "next-intl": "^4.13.0",
    "nodemailer": "^6.9.16",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "sharp@0.33.5": true,
    "esbuild@0.18.20": true,
    "esbuild@0.19.12": true,
    "esbuild@0.28.1": true,
    "unrs-resolver@1.12.2": true
  }
}
