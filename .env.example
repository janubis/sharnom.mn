# ──────────────────────────────────────────────────────────────────────────
# Mongol Local — environment configuration
# Copy to `.env.local` for development. Never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME="Mongol Local"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── PostgreSQL + PostGIS ────────────────────────────────────────────────────
# Local docker-compose service `postgres`, a native install, or a Supabase pooler URL.
DATABASE_URL="postgresql://mongol:mongol@localhost:5432/mongol_local"

# ── Supabase (optional managed Postgres host) ───────────────────────────────
# Set DATABASE_URL above to the Supabase *Session pooler* string (IPv4) to use it.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""      # sb_publishable_... (client-safe)
SUPABASE_DB_PASSWORD=""

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Generate: `openssl rand -base64 32`
AUTH_SECRET="change-me-in-production"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# OAuth providers (leave blank to disable a provider in dev)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# Email (magic-link) — optional; uses Resend/SMTP
AUTH_EMAIL_FROM="no-reply@mongol-local.mn"
AUTH_EMAIL_SERVER="smtp://user:pass@localhost:1025"

# ── Redis (cache, rate-limit, queues) ───────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── OpenSearch (Stage 2 search) ─────────────────────────────────────────────
OPENSEARCH_URL="http://localhost:9200"
OPENSEARCH_USERNAME="admin"
OPENSEARCH_PASSWORD="admin"
OPENSEARCH_INDEX="businesses"
# Feature flag: when false, search falls back to PostgreSQL (Stage 1).
SEARCH_ENGINE="postgres" # postgres | opensearch

# ── ClickHouse (analytics events) ───────────────────────────────────────────
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_USER="default"
CLICKHOUSE_PASSWORD=""
CLICKHOUSE_DATABASE="mongol_local_analytics"
# When false, analytics events are written to the Postgres fallback table only.
ANALYTICS_SINK="postgres" # postgres | clickhouse

# ── Object storage (S3-compatible: AWS S3 / Cloudflare R2 / MinIO) ──────────
S3_ENDPOINT="http://localhost:9100"
S3_REGION="us-east-1"
S3_BUCKET="mongol-local-media"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true" # required for MinIO
NEXT_PUBLIC_MEDIA_BASE_URL="http://localhost:9100/mongol-local-media"

# ── Maps ────────────────────────────────────────────────────────────────────
# Provider abstraction default. `maplibre` | `google`
NEXT_PUBLIC_MAP_PROVIDER="maplibre"
# Self-hosted OpenMapTiles / commercial style URL. Do NOT use public OSM tiles in prod.
NEXT_PUBLIC_MAP_STYLE_URL="http://localhost:8080/styles/basic/style.json"
# Default map centre = Ulaanbaatar (Sükhbaatar Square)
NEXT_PUBLIC_MAP_DEFAULT_LAT="47.918"
NEXT_PUBLIC_MAP_DEFAULT_LNG="106.917"
NEXT_PUBLIC_MAP_DEFAULT_ZOOM="12"
# Hosted tiles: a free MapTiler key gives production-grade tiles incl. Mongolia.
#   NEXT_PUBLIC_MAP_STYLE_URL="https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_KEY"
NEXT_PUBLIC_MAPTILER_KEY=""
# Optional Google Maps key (only used when provider = google)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ── Analytics & monitoring (inert until set) ────────────────────────────────
NEXT_PUBLIC_GA_ID=""        # GA4 measurement id, e.g. G-XXXXXXX
NEXT_PUBLIC_SENTRY_DSN=""   # Sentry DSN (client + server error monitoring)

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED="true"
